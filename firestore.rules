rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Tasks collection
    match /tasks/{taskId} {
      // Allow read/write only if the user is authenticated and the task belongs to them
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      // Allow create only if the authenticated user is assigning the task to themselves
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      // Allow update only if the task belongs to the authenticated user and they aren't changing the userId
      allow update: if request.auth != null 
                    && resource.data.userId == request.auth.uid
                    && request.resource.data.userId == request.auth.uid;
      // Allow delete only if the task belongs to the authenticated user
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
  }
}
